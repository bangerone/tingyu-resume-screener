# ============================================================
# 庭宇 简历筛选系统 — 国内栈环境变量
# ============================================================

# ===== Database — TiDB Cloud Serverless (MySQL 协议) =====
# 在 https://tidbcloud.com 创建免费 Serverless 集群（可选 region: AWS Tokyo）
# Connection string 模板：mysql://<user>.root:<password>@<host>:4000/<db>?ssl={"rejectUnauthorized":true}
DATABASE_URL=

# ===== JWT — 自实现 Auth =====
# 至少 32 字节随机串：openssl rand -base64 32
JWT_SECRET=
# JWT 过期时间（秒），默认 7 天
JWT_TTL_SECONDS=604800

# ===== HR Auth =====
HR_ACCESS_PASSWORD=changeme

# ===== AI Provider (OpenAI compatible) =====
# default: deepseek (国内 API，稳定快)
AI_PROVIDER=deepseek
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL_PARSE=deepseek-chat
AI_MODEL_SCORE=deepseek-chat

# ===== Email — 候选人验证码 =====
# dev 环境下若未配置 Resend API Key，验证码会打印到 server console
# 生产环境用 Resend (https://resend.com 3000 封/月免费)
RESEND_API_KEY=
EMAIL_FROM="庭宇招聘 <noreply@yourdomain.com>"

# ===== 腾讯云 COS（简历存储）=====
# https://console.cloud.tencent.com/cos
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=tingyu-resumes-1234567890
COS_REGION=ap-guangzhou
# CDN/直链域名（带 https），用于前端 STS 直传后访问
COS_PUBLIC_HOST=

# ===== 飞书自定义群机器人 =====
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=

# ===== App =====
APP_BASE_URL=http://localhost:3000
# dev 模式开关（true 时邮箱验证码会在控制台打印）
NODE_ENV=development

# ===== D6.5 演示加固（可选）=====
# 任一变量为空 / 未设置 → 对应护栏关闭，不影响本地 dev。
# 线上演示环境建议三个都设；详见 docs/tasks/D6.5-demo-hardening.md
#
# HR 只读模式：管理员登录后所有写操作返回 403（建/改/删岗位、重推飞书、重新评分）
DEMO_READONLY_HR=
# 访问码门禁：全站需 cookie `demo-access=1`；缺 cookie → 302 /welcome?next=...
# 面试官直接用 https://<域名>/welcome?k=<code> 进入即可（cookie 保留 30 天）
DEMO_ACCESS_CODE=
# 每个候选人最多投递数（防刷）；留空或 0 → 无限制
DEMO_MAX_APPLICATIONS_PER_CANDIDATE=
